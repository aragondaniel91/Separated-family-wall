{
  "name": "GroceryItem",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Item name"
    },
    "quantity": {
      "type": "string",
      "description": "Quantity needed"
    },
    "category": {
      "type": "string",
      "enum": [
        "produce",
        "dairy",
        "meat",
        "bakery",
        "frozen",
        "pantry",
        "beverages",
        "snacks",
        "household",
        "other"
      ],
      "default": "other"
    },
    "checked": {
      "type": "boolean",
      "default": false
    },
    "linked_meal": {
      "type": "string",
      "description": "Optional meal this item is for"
    }
  },
  "required": [
    "name"
  ]
}