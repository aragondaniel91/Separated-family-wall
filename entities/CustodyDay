{
  "name": "CustodyDay",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "description": "The date"
    },
    "with_whom": {
      "type": "string",
      "enum": [
        "dad",
        "mom"
      ],
      "description": "Who the child is with all day (used when no split)"
    },
    "morning": {
      "type": "string",
      "enum": [
        "dad",
        "mom"
      ],
      "description": "Who has the child in the morning"
    },
    "afternoon": {
      "type": "string",
      "enum": [
        "dad",
        "mom"
      ],
      "description": "Who has the child in the afternoon"
    },
    "is_split": {
      "type": "boolean",
      "default": false,
      "description": "True if the day is split between parents"
    },
    "notes": {
      "type": "string",
      "description": "Optional notes for this day"
    }
  },
  "required": [
    "date"
  ]
}